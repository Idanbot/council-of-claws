POSTGRES_DB=council
POSTGRES_USER=council
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgresql://council:change-me@postgres:5432/council
MOCK_MODE=false
TIMEZONE=UTC

GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=council-local-gateway-token
BACKEND_PORT=8080
DASHBOARD_PORT=3000

BACKEND_IMAGE=council/backend:local
DASHBOARD_IMAGE=council/dashboard:local
GATEWAY_IMAGE=council/gateway:local
# For remote deploys, point these at the GHCR tags published by CI, for example:
# BACKEND_IMAGE=ghcr.io/<owner>/council-of-claws-backend:main
# DASHBOARD_IMAGE=ghcr.io/<owner>/council-of-claws-dashboard:main
# GATEWAY_IMAGE=ghcr.io/<owner>/council-of-claws-gateway:main
# Validated OpenClaw image: 2026.4.15
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw@sha256:9d5f1dfbd5deedc37706c78f745b958ffbe9b4f20840cfb4d49c617a50326902
OPENCLAW_DATABASE_URL=postgresql://council:change-me@postgres:5432/council

CLOUDFLARED_TOKEN=
# Rotate these before deploying to another machine.
AGENT_TOKENS=director=change-me-director

# Telegram Bot Integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Remote AI Model Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
EXA_API_KEY=

# Optional helper when calling the backend from a client inside the compose network
# COC_BACKEND_BASE_URL=http://backend:8080

# Optional override when testing another upstream gateway image:
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:main

REMOTE_WORKER_IMAGE=alpine:3.20
