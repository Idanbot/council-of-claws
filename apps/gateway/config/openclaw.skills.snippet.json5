// Legacy reference from the older inline shell-skill approach.
// This file is not loaded automatically by the compose stack.
// The active v1 path now uses repo-local skills under .agents/skills and
// the current OpenClaw config model in apps/gateway/config/openclaw.json5.

{
  model_pool: [
    {
      id: "cheap",
      provider: "groq",
      model: "llama-3.1-8b-instant",
      api_key: "${GROQ_API_KEY}",
      priority: 1,
    },
    {
      id: "premium",
      provider: "groq",
      model: "llama-3.3-70b-versatile",
      api_key: "${GROQ_API_KEY}",
      priority: 2,
    },
    {
      id: "heavy",
      provider: "google",
      model: "gemini-1.5-pro",
      api_key: "${GEMINI_API_KEY}",
      priority: 3,
    },
    {
      id: "fallback",
      provider: "google",
      model: "gemini-1.5-flash",
      api_key: "${GEMINI_API_KEY}",
      priority: 4,
    },
  ],

  routing: {
    front_agent: "contractor",
    planner_agent: "director",
    default_review_mode: "light",
  },

  skills: [
    {
      id: "coc-tool",
      type: "shell",
      path: "/workspace/scripts/coc-tool/coc-tool",
      description: "Primary interface for the Council of Claws backend. Supports: health, mission-create, task-create, mission-close.",
      env: {
        COC_BACKEND_BASE_URL: "http://backend:8080",
      },
    },
    {
      id: "web-search",
      type: "shell",
      path: "/usr/bin/curl",
      description: "Search the web and return AI-clean markdown results. No key required.",
      args: ["-s", "https://s.jina.ai/{{query}}"],
    },
    {
      id: "web-reader",
      type: "shell",
      path: "/usr/bin/curl",
      description: "Read any URL and return clean markdown content stripped of ads/SEO. No key required.",
      args: ["-s", "https://r.jina.ai/{{url}}"],
    },
    {
      id: "sql-explorer-ro",
      type: "shell",
      path: "/usr/bin/psql",
      description: "Read-only access to the platform database for auditing.",
      env: {
        PGPASSWORD: "${POSTGRES_PASSWORD}",
      },
      args: ["-h", "postgres", "-U", "${POSTGRES_USER}", "-d", "${POSTGRES_DB}", "-c", "{{query}}"],
    },
    {
      id: "redis-explorer-ro",
      type: "shell",
      path: "/usr/bin/redis-cli",
      description: "Read-only inspection of the real-time event bus.",
      args: ["-h", "redis", "get", "{{key}}"],
    },
    {
      id: "file-manager",
      type: "shell",
      path: "/usr/bin/ls",
      description: "Repository file structure inspection.",
      args: ["-R", "/workspace"],
    },
    {
      id: "obsidian-advanced",
      type: "shell",
      path: "/usr/bin/find",
      description: "Deep vault search and discovery.",
      args: ["/obsidian", "-name", "*{{pattern}}*"],
    },
  ],

  agents: [
    {
      id: "contractor",
      role: "front-door",
      model: "cheap",
      can_create_tasks: true,
      can_run_shell: false,
      skills: ["coc-tool", "web-search", "web-reader", "file-manager"],
    },
    {
      id: "director",
      role: "planner",
      model: "premium",
      can_create_tasks: true,
      can_run_shell: false,
      skills: ["coc-tool", "web-search", "web-reader", "sql-explorer-ro", "redis-explorer-ro", "obsidian-advanced"],
    },
    {
      id: "architect",
      role: "design-review",
      model: "heavy",
      can_create_tasks: true,
      can_run_shell: false,
      skills: ["coc-tool", "obsidian-advanced", "file-manager", "web-reader"],
    },
    {
      id: "senior_engineer",
      role: "implementation",
      model: "premium",
      fallback_model: "heavy",
      can_create_tasks: true,
      can_run_shell: true,
      skills: ["coc-tool", "file-manager", "web-search", "web-reader"],
    },
    {
      id: "junior_engineer",
      role: "qa-review",
      model: "cheap",
      fallback_model: "premium",
      can_create_tasks: true,
      can_run_shell: true,
      skills: ["coc-tool", "file-manager", "web-reader"],
    },
    {
      id: "intern",
      role: "notifications",
      model: "cheap",
      can_create_tasks: true,
      can_run_shell: false,
      skills: ["coc-tool", "web-reader"],
    },
  ],
}
